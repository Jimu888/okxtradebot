# Anthropic API Key (get from https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxx

# OKX Profile name (configured via `okx config init`)
OKX_PROFILE=live

# How often to run strategy cycle in seconds (default: 300 = 5 minutes)
LOOP_INTERVAL_SECONDS=300

# Claude model (haiku is cheapest, opus is most capable)
# claude-haiku-4-5-20251001  ← recommended, ~$0.50/day
# claude-sonnet-4-6          ← more capable, ~$3/day
# claude-opus-4-6            ← most capable, ~$20/day
CLAUDE_MODEL=claude-haiku-4-5-20251001
